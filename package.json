{
  "name": "agents-hub",
  "version": "1.0.0",
  "description": "> **The open registry & spec for API‑savvy LLM agents — built in public, one thoughtful file at a time.**",
  "main": "index.js",
  "bin": {
    "agent-hub": "bin/agent-hub.js"
  },
  "scripts": {
    "gen-mcp": "node scripts/gen-mcp-manifest.js",
    "sync-agents": "node scripts/sync-agents-static.js",
    "validate:agent-pack": "node scripts/validate-agent-pack-v0.4.0.js",
    "validate:claude-skill": "node scripts/validate-claude-skill-pack.js",
    "generate:claude-skill": "node scripts/pack-to-claude-skill.js",
    "generate:claude-skill:pilot": "node scripts/pack-to-claude-skill.js --pilot",
    "generate:claude-skill:all": "node scripts/pack-to-claude-skill.js --all",
    "check:claude-skill": "node scripts/pack-to-claude-skill.js --pilot --check",
    "check:claude-skill:all": "node scripts/pack-to-claude-skill.js --all --check",
    "install:claude-skill": "node scripts/install-claude-skill.js",
    "install:claude-skill:pilot": "node scripts/install-claude-skill.js --pilot",
    "check:mcp-distributions": "node scripts/check-mcp-distribution-tools.mjs",
    "check:claude-code-local-setup": "node scripts/check-claude-code-local-setup.js",
    "check:claude-code-skill-runtime": "node scripts/check-claude-code-skill-runtime.js",
    "build:site": "cd website && npm install && npm run build",
    "build": "npm run gen-mcp && npm run sync-agents && npm run build:site"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.1",
    "fetch-to-node": "^2.1.0",
    "zod": "^3.23.8"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
